---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import heroImage from "../assets/lagrange.png";

interface Props {
  locale: string;
  class?: string;
}

const { locale, class: className } = Astro.props;
const entry = await getEntry("hero", locale);
if (!entry) throw new Error(`Missing hero content for locale: ${locale}`);
---

<section id="welcome" class:list={["",className]}>
  <div class="hero min-h-[calc(100dvh-var(--header-height))]">
    <Image
      src={heroImage}
      alt=""
      class="relative h-full object-cover object-bottom sm:object-center dark:opacity-95"
      widths={[800, 1200, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-black/20"></div>

    <div class="hero-content text-center">
      <div>
        <h1 class="mb-4 font-normal tracking-[0.1em] text-white opacity-90">
          <span class="block text-7xl sm:text-8xl lg:text-9xl">La Grange</span>
          <span class="block text-3xl sm:text-4xl lg:text-5xl">de Marie France</span>
        </h1>
        <p class="text-lg text-white/90 sm:text-xl lg:text-2xl">{entry.data.tagline}</p>
        <a href="#contact" class="btn btn-primary mt-20">
          {entry.data.cta}
        </a>
      </div>
    </div>
  </div>
</section>
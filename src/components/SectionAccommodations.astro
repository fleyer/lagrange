---
import { getEntry } from "astro:content";

interface Props {
  locale: string;
  class?: string;
}

const { locale, class: className } = Astro.props;
const entry = await getEntry("accommodations", locale);
if (!entry)
  throw new Error(`Missing accommodations content for locale: ${locale}`);
---

<section id="accommodations" class:list={["min-h-[80svh] bg-section px-4 py-16", className]}>
  <div class="mx-auto max-w-4xl">
    <h2 class="mb-10 text-center text-4xl font-normal text-head sm:text-5xl lg:text-6xl">{entry.data.title}</h2>

    <div class="mb-12 grid gap-6 sm:grid-cols-3">
      {entry.data.units.map((unit) => (
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-head">{unit.name}</h3>
          <p class="mb-3 text-sub">{unit.capacity}</p>
          <p class="leading-relaxed text-body">{unit.description}</p>
        </div>
      ))}
    </div>

    <div class="mx-auto max-w-sm">
      {entry.data.pricing.map((row) => (
        <div class="flex justify-between border-b border-stone-200 py-2 text-body">
          <span>{row.label}</span>
          <span class="font-medium">{row.price}</span>
        </div>
      ))}
    </div>
  </div>
</section>

---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";

interface Props {
  locale: string;
  class?: string;
}

const { locale, class: className } = Astro.props;
const entry = await getEntry("accommodations", locale);
if (!entry)
  throw new Error(`Missing accommodations content for locale: ${locale}`);

const imagesEntry = await getEntry("accommodationsImages", "index");
if (!imagesEntry) throw new Error("Missing accommodations images");

const unitImages = imagesEntry.data.units;
---

<section id="accommodations" class:list={["min-h-[80svh] bg-base-200 px-4 py-16", className]}>
  <div class="mx-auto max-w-4xl">
    <h2 class="mb-10 text-center text-4xl font-normal text-base-content sm:text-5xl lg:text-6xl">{entry.data.title}</h2>

    <div class="mb-12 grid gap-6 sm:grid-cols-3">
      {entry.data.units.map((unit, i) => {
        const unitConfig = unitImages.find(unitImage => unitImage.id === unit.id);
        const images = unitConfig?.images ?? []
        const color = unitImages[i]?.color;

        return (
          <div class={`card shadow-sm overflow-hidden ${color ? "border-solid border-2" : ""}`} style={ color ? {"border-color": color} : {}}}>
            {images.length > 0 && (
              <figure class="relative h-48 overflow-visible">
                <div class="carousel h-full w-full">
                  {images.map((img, j) => (
                    <div class="carousel-item h-full w-full">
                      <Image
                        src={img}
                        alt={`${unit.name} — photo ${j + 1}`}
                        class="h-full w-full object-cover"
                      />
                    </div>
                  ))}
                </div>
                {images.length > 1 && (
                  <div class="absolute bottom-2 flex w-full justify-center gap-1.5">
                    {images.map((_, j) => (
                      <button
                        data-slide-index={j}
                        class="h-2 w-2 rounded-full border-0 bg-white p-0 opacity-60 transition-opacity hover:opacity-100 cursor-pointer"
                        aria-label={`Photo ${j + 1}`}
                      />
                    ))}
                  </div>
                )}
              </figure>
            )}
            <div class="card-body">
              <h3 class="card-title text-base-content" style={{color: color }}>{unit.name}</h3>
              <p class="text-sm text-base-content/60">{unit.capacity}</p>
              <p class="text-base-content" set:html={unit.description}></p>
            </div>
          </div>
        );
      })}
    </div>

    <div class="list shadow-sm rounded-box mx-auto max-w-sm">
      {entry.data.pricing.map((row) => (
        <div class="list-row flex justify-between py-2 text-base-content">
          <span>{row.label}</span>
          <span class="font-medium">{row.price}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-slide-index]").forEach((dot) => {
    dot.addEventListener("click", () => {
      const index = parseInt(dot.dataset.slideIndex!);
      const carousel = dot.closest("figure")!.querySelector(".carousel")!;
      const item = carousel.querySelectorAll<HTMLElement>(".carousel-item")[index];
      carousel.scrollTo({ left: item.offsetLeft, behavior: "smooth" });
    });
  });
</script>

---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";

interface Props {
  locale: string;
  class?: string;
}

const { locale, class: className } = Astro.props;
const entry = await getEntry("dining", locale);
if (!entry) throw new Error(`Missing dining content for locale: ${locale}`);
---

<section id="dining" class:list={["flex min-h-[80svh] flex-col items-center justify-center bg-base-100 px-4 py-16", className]}>
  <div class="mx-auto w-full max-w-4xl py-4">
    <h2 class="mb-12 text-center font-normal text-base-content text-xl sm:text-5xl lg:text-6xl">{entry.data.title}</h2>

    {entry.data.meals.map((meal, i) => (
      <Fragment>
        {i > 0 && <hr class="my-10 border-base-300" />}

        {meal.image ? (
          <div class:list={["flex flex-col gap-8 sm:grid sm:grid-cols-2 sm:items-center", i % 2 === 1 && "sm:[&>*:first-child]:order-2"]}>
            <div class="overflow-hidden rounded-lg">
              <Image
                src={meal.image}
                alt={meal.name}
                class="aspect-[4/3] w-full object-cover"
              />
            </div>
            <div class="text-center">
              <h3 class="text-lg uppercase tracking-[0.2em] text-base-content">{meal.name}</h3>
              {meal.note && <p class="mt-1 text-sm text-base-content/40 italic">{meal.note}</p>}
              {meal.description && <p class="mt-3 text-sm text-base-content/60 italic">{meal.description}</p>}
              <ul class="mt-5 list-none space-y-1.5 p-0">
                {meal.items.map((item) => (
                  <li class="text-base-content">{item}</li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <div class="text-center">
            <h3 class="text-lg uppercase tracking-[0.2em] text-base-content">{meal.name}</h3>
            {meal.note && <p class="mt-1 text-sm text-base-content/40 italic">{meal.note}</p>}
            {meal.description && <p class="mt-3 text-sm text-base-content/60 italic">{meal.description}</p>}
            <ul class="mt-5 list-none space-y-1.5 p-0">
              {meal.items.map((item) => (
                <li class="text-base-content">{item}</li>
              ))}
            </ul>
          </div>
        )}
      </Fragment>
    ))}
  </div>
</section>

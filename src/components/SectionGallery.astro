---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import * as m from "../paraglide/messages.js";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const entry = await getEntry("gallery", "index");
if (!entry) throw new Error("Missing gallery content");

const { images } = entry.data;
---

<section id="gallery" class:list={["bg-base-200 px-4 py-16", className]}>
  <div class="mx-auto max-w-5xl py-4">
    <h2 class="mb-10 text-center text-4xl font-normal text-base-content sm:text-5xl lg:text-6xl">
      {m.galleryTitle()}
    </h2>
    <div class="columns-2 gap-4 md:columns-3">
      {images.map((img, i) => (
        <div class="mb-4 break-inside-avoid">
          <Image
            src={img.src}
            alt={img.alt}
            width={600}
            class="w-full rounded-xl"
            loading={i < 2 ? "eager" : "lazy"}
          />
        </div>
      ))}
    </div>
  </div>
</section>

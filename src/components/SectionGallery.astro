---
import * as m from "../paraglide/messages.js";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section id="gallery" class:list={["flex min-h-[80svh] flex-col items-center justify-center bg-section px-4 py-16 text-center", className]}>
  <div class="mx-auto max-w-2xl">
    <h2 class="mb-6 font-normal text-head sm:text-5xl lg:text-6xl">{m.galleryTitle()}</h2>
    <p class="text-lg leading-relaxed text-body">{m.galleryPlaceholder()}</p>
  </div>
</section>

---
const links = [
  { href: "#the-refuge", label: "The Refuge" },
  { href: "#accommodations", label: "Accommodations" },
  { href: "#dining", label: "Dining" },
  { href: "#gallery", label: "Gallery" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-100 flex flex-col gap-3 border-b border-stone-100 bg-stone-50 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-8">
  <a href="#hero" class="text-xl font-bold tracking-widest text-stone-900 no-underline">
    Lagrange
  </a>
  <nav class="flex flex-wrap gap-4 sm:gap-8">
    {links.map(({ href, label }) => (
      <a href={href} class="text-sm tracking-wide text-stone-900 no-underline hover:underline">
        {label}
      </a>
    ))}
  </nav>
</header>

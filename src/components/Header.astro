---
import * as m from "../paraglide/messages.js";

const locales = [
  { code: "fr", label: "FR", href: "/" },
  { code: "en", label: "EN", href: "/en/" },
  { code: "de", label: "DE", href: "/de/" },
  { code: "es", label: "ES", href: "/es/" },
];
const currentLocale = Astro.currentLocale ?? "fr";
---

<header class="sticky top-0 z-50 border-b border-stone-100 bg-stone-50">
  <!-- Hidden checkbox drives the mobile menu open/close state -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer sr-only" />

  <!-- Header bar -->
  <div class="navbar px-4 sm:px-8">

    <!-- Brand -->
    <div class="navbar-start">
      <a href="#hero" class="text-xl font-bold tracking-widest text-stone-900 no-underline">Lagrange</a>
    </div>

    <!-- Desktop centered nav -->
    <nav class="navbar-center hidden gap-6 md:inline-flex lg:gap-8">
      <a href="#hero" class="text-sm tracking-wide text-stone-900 no-underline hover:underline">{m.navHome()}</a>
      <a href="#the-refuge" class="text-sm tracking-wide text-stone-900 no-underline hover:underline">{m.navRefuge()}</a>
      <a href="#accommodations" class="text-sm tracking-wide text-stone-900 no-underline hover:underline">{m.navAccommodations()}</a>
      <a href="#dining" class="text-sm tracking-wide text-stone-900 no-underline hover:underline">{m.navDining()}</a>
      <a href="#gallery" class="text-sm tracking-wide text-stone-900 no-underline hover:underline">{m.navGallery()}</a>
      <a href="#contact" class="text-sm tracking-wide text-stone-900 no-underline hover:underline">{m.navContact()}</a>
    </nav>

    <!-- Right: language dropdown (desktop) + hamburger (mobile) -->
    <div class="navbar-end gap-4">
      <details class="dropdown dropdown-end hidden md:block">
        <summary class="flex cursor-pointer list-none items-center gap-1 rounded px-2 py-1 text-sm font-semibold tracking-widest text-stone-900 hover:bg-stone-100">
          {locales.find(l => l.code === currentLocale)?.label}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <ul class="menu dropdown-content z-50 mt-1 w-24 rounded-box border border-stone-100 bg-stone-50 p-1 shadow">
          {locales.map(({ code, label, href }) => (
            <li>
              {code === currentLocale ? (
                <span class="text-sm font-semibold tracking-widest text-stone-900">{label}</span>
              ) : (
                <a href={href} class="text-sm font-semibold tracking-widest text-stone-400 no-underline hover:text-stone-900">{label}</a>
              )}
            </li>
          ))}
        </ul>
      </details>
      <label for="mobile-menu-toggle" class="btn btn-ghost btn-square btn-sm text-stone-900 md:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
    </div>
  </div>

  <!-- Full-screen mobile menu overlay (visible when checkbox is checked) -->
  <div class="fixed inset-0 z-50 hidden flex-col bg-stone-50 peer-checked:flex md:hidden">

    <!-- Overlay top bar with close button -->
    <div class="flex items-center justify-between border-b border-stone-100 px-4 py-4 sm:px-8">
      <span class="text-xl font-bold tracking-widest text-stone-900">Lagrange</span>
      <label for="mobile-menu-toggle" class="btn btn-ghost btn-square btn-sm text-stone-900">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </label>
    </div>

    <!-- Nav links -->
    <nav class="flex flex-1 flex-col items-center justify-center gap-8">
      <a href="#hero" class="text-lg tracking-wide text-stone-900 no-underline hover:underline">{m.navHome()}</a>
      <a href="#the-refuge" class="text-lg tracking-wide text-stone-900 no-underline hover:underline">{m.navRefuge()}</a>
      <a href="#accommodations" class="text-lg tracking-wide text-stone-900 no-underline hover:underline">{m.navAccommodations()}</a>
      <a href="#dining" class="text-lg tracking-wide text-stone-900 no-underline hover:underline">{m.navDining()}</a>
      <a href="#gallery" class="text-lg tracking-wide text-stone-900 no-underline hover:underline">{m.navGallery()}</a>
      <a href="#contact" class="text-lg tracking-wide text-stone-900 no-underline hover:underline">{m.navContact()}</a>
    </nav>

    <!-- Language switcher -->
    <div class="border-t border-stone-100 px-8 py-6">
      <div class="flex justify-center gap-6">
        {locales.map(({ code, label, href }) =>
          code === currentLocale ? (
            <span class="text-sm font-semibold tracking-widest text-stone-900">{label}</span>
          ) : (
            <a href={href} class="text-sm font-semibold tracking-widest text-stone-400 no-underline hover:text-stone-900">{label}</a>
          )
        )}
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle") as HTMLInputElement | null;
  if (toggle) {
    document.querySelectorAll("a[href^='#']").forEach((a) => {
      a.addEventListener("click", () => { toggle.checked = false; });
    });
  }
</script>

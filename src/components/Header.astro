---
import { ChevronDown, Menu, X } from "@lucide/astro";
import * as m from "../paraglide/messages.js";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const locales = [
  { code: "fr", label: "FR", href: `${base}/` },
  { code: "en", label: "EN", href: `${base}/en/` },
  { code: "de", label: "DE", href: `${base}/de/` },
  { code: "es", label: "ES", href: `${base}/es/` },
];
const currentLocale = Astro.currentLocale ?? "fr";
---

<header class="sticky top-0 z-50 border-b bg-base-100 border-base-300">
  <!-- Hidden checkbox drives the mobile menu open/close state -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer sr-only" />

  <!-- Header bar -->
  <div class="navbar px-4 sm:px-8">

    <!-- Brand -->
    <div class="navbar-start">
      <a href="#hero" class="text-xl font-bold tracking-widest no-underline text-base-content">Lagrange</a>
    </div>

    <!-- Desktop centered nav -->
    <nav class="navbar-center hidden gap-6 md:inline-flex lg:gap-8">
      <a href="#hero" class="text-sm tracking-wide no-underline hover:underline text-base-content">{m.navHome()}</a>
      <a href="#the-refuge" class="text-sm tracking-wide no-underline hover:underline text-base-content">{m.navRefuge()}</a>
      <a href="#accommodations" class="text-sm tracking-wide no-underline hover:underline text-base-content">{m.navAccommodations()}</a>
      <a href="#dining" class="text-sm tracking-wide no-underline hover:underline text-base-content">{m.navDining()}</a>
      <a href="#gallery" class="text-sm tracking-wide no-underline hover:underline text-base-content">{m.navGallery()}</a>
      <a href="#contact" class="text-sm tracking-wide no-underline hover:underline text-base-content">{m.navContact()}</a>
    </nav>

    <!-- Right: language dropdown (desktop) + hamburger (mobile) -->
    <div class="navbar-end gap-4">
      <details class="dropdown dropdown-end hidden md:block">
        <summary class="flex cursor-pointer list-none items-center gap-1 rounded px-2 py-1 text-sm font-semibold tracking-widest text-base-content hover:bg-base-200">
          {locales.find(l => l.code === currentLocale)?.label}
          <ChevronDown class="h-3 w-3" stroke-width={2.5} />
        </summary>
        <ul class="menu dropdown-content z-50 mt-1 w-24 rounded-box border p-1 shadow bg-base-100 border-base-300">
          {locales.map(({ code, label, href }) => (
            <li>
              {code === currentLocale ? (
                <span class="text-sm font-semibold tracking-widest text-base-content">{label}</span>
              ) : (
                <a href={href} class="text-sm font-semibold tracking-widest no-underline text-base-content/40 hover:text-base-content">{label}</a>
              )}
            </li>
          ))}
        </ul>
      </details>
      <label for="mobile-menu-toggle" class="btn btn-ghost btn-square btn-sm md:hidden text-base-content">
        <Menu class="h-5 w-5" />
      </label>
    </div>
  </div>

  <!-- Full-screen mobile menu overlay (visible when checkbox is checked) -->
  <div class="fixed inset-0 z-50 hidden flex-col peer-checked:flex md:hidden bg-base-100">

    <!-- Overlay top bar with close button -->
    <div class="flex items-center justify-between border-b px-4 py-4 sm:px-8 border-base-300">
      <span class="text-xl font-bold tracking-widest text-base-content">Lagrange</span>
      <label for="mobile-menu-toggle" class="btn btn-ghost btn-square btn-sm text-base-content">
        <X class="h-5 w-5" />
      </label>
    </div>

    <!-- Nav links -->
    <nav class="flex flex-1 flex-col items-center justify-center gap-8">
      <a href="#hero" class="text-lg tracking-wide no-underline hover:underline text-base-content">{m.navHome()}</a>
      <a href="#the-refuge" class="text-lg tracking-wide no-underline hover:underline text-base-content">{m.navRefuge()}</a>
      <a href="#accommodations" class="text-lg tracking-wide no-underline hover:underline text-base-content">{m.navAccommodations()}</a>
      <a href="#dining" class="text-lg tracking-wide no-underline hover:underline text-base-content">{m.navDining()}</a>
      <a href="#gallery" class="text-lg tracking-wide no-underline hover:underline text-base-content">{m.navGallery()}</a>
      <a href="#contact" class="text-lg tracking-wide no-underline hover:underline text-base-content">{m.navContact()}</a>
    </nav>

    <!-- Language switcher -->
    <div class="border-t px-8 py-6 border-base-300">
      <div class="flex justify-center gap-6">
        {locales.map(({ code, label, href }) =>
          code === currentLocale ? (
            <span class="text-sm font-semibold tracking-widest text-base-content">{label}</span>
          ) : (
            <a href={href} class="text-sm font-semibold tracking-widest no-underline text-base-content/40 hover:text-base-content">{label}</a>
          )
        )}
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle") as HTMLInputElement | null;
  if (toggle) {
    document.querySelectorAll("a[href^='#']").forEach((a) => {
      a.addEventListener("click", () => { toggle.checked = false; });
    });
  }
</script>

---
import { getEntry, render } from "astro:content";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const entry = await getEntry("refuge", locale);
if (!entry) throw new Error(`Missing refuge content for locale: ${locale}`);
const { Content } = await render(entry);
---

<section id="the-refuge" class="flex min-h-[80svh] flex-col items-center justify-center px-4 py-16 text-center">
  <div class="mx-auto max-w-2xl">
    <h2 class="mb-6 text-4xl font-normal sm:text-5xl lg:text-6xl">{entry.data.title}</h2>
    <div class="text-lg leading-relaxed text-stone-500">
      <Content />
    </div>
  </div>
</section>

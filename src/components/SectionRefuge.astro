---
import { Image } from "astro:assets";
import { getEntry, render } from "astro:content";
import {
  Bus,
  Luggage,
  MapPin,
  Volume2,
  WashingMachine,
  Wind,
} from "@lucide/astro";
import laGrangeLogo from "../assets/lagrange-logo.png";

const highlightIcons = [MapPin, Volume2, Wind, Bus, Luggage, WashingMachine];

interface Props {
  locale: string;
  class?: string;
}

const { locale, class: className } = Astro.props;
const entry = await getEntry("refuge", locale);
if (!entry) throw new Error(`Missing refuge content for locale: ${locale}`);
const { Content } = await render(entry);
---

<section id="the-refuge" class:list={["flex min-h-[80svh] flex-col items-center justify-center bg-section px-4 py-16 text-center", className]}>
  <div class="mx-auto max-w-2xl">
    <div class="hero">
      
      <div class="hero-content flex flex-col sm:flex-row items-stretch ">
        <figure class="flex justify-center p-4 px-10 rounded-sm dark:bg-(--color-stone-100)/95">
          <Image
            src={laGrangeLogo}
            alt="walking man" 
            class="max-h-48 sm:max-h-none h-full w-auto"/>
        </figure>
        <div class="px-6 flex flex-col">
          <h2 class="mb-6 font-normal text-head sm:text-5xl lg:text-6xl">{entry.data.title}</h2>
          <div class="leading-relaxed text-sub my-6">
            <Content />
          </div>
          <div class="flex-1 flex justify-center gap-2">
            <a href="#accommodations" class="btn">{entry.data.discover}</a>
            <a href="#contact" class="btn">{entry.data.gettingThere}</a>
          </div>  
        </div>
      </div>  
    </div>
  <div class="mx-auto max-w-2xl">
    <div class="p-6 text-start">
      {entry.data.highlights && (
        <>
          {entry.data.highlightsTitle && <h3 class="mt-6 mb-2 text-muted text-lg">{entry.data.highlightsTitle}</h3>}
          <div class="flex flex-wrap gap-2">
            {entry.data.highlights.map((item, i) => {
              const Icon = highlightIcons[i] ?? MapPin;
              return (
                <div class="flex items-center text-sm text-body p-2 border border-solid rounded-sm">
                  <Icon class="h-4 w-4 shrink-0 text-sub m-2" />
                  <span class="list-col-grow">{item}</span>
                </div>
              );
            })}
          </div>
          
        </>
      )}
    </div>
  </div>
  </div>
</section>

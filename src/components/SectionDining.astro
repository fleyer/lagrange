---
import { getEntry, render } from "astro:content";

const { locale } = Astro.props;
const entry = await getEntry("dining", locale);
if (!entry) throw new Error(`Missing dining content for locale: ${locale}`);
const { Content } = await render(entry);
---

<section id="dining" class="flex min-h-[80svh] flex-col items-center justify-center px-4 py-16">
  <div class="mx-auto max-w-2xl">
    <h2 class="mb-8 text-center text-4xl font-normal sm:text-5xl lg:text-6xl">{entry.data.title}</h2>
    <div class="prose prose-stone mx-auto text-stone-600">
      <Content />
    </div>
  </div>
</section>

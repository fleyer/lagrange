---
import { getEntry } from "astro:content";

interface Props {
  locale: string;
  class?: string;
}

const { locale, class: className } = Astro.props;
const entry = await getEntry("dining", locale);
if (!entry) throw new Error(`Missing dining content for locale: ${locale}`);
---

<section id="dining" class:list={["flex min-h-[80svh] flex-col items-center justify-center bg-section px-4 py-16", className]}>
  <div class="mx-auto w-full max-w-sm text-center">
    <h2 class="mb-12 font-normal text-head sm:text-5xl lg:text-6xl">{entry.data.title}</h2>

    {entry.data.meals.map((meal, i) => (
      <Fragment>
        {i > 0 && <hr class="my-10 border-stone-300" />}
        <div>
          <h3 class="text-lg uppercase tracking-[0.2em] text-head">{meal.name}</h3>
          {meal.note && <p class="mt-1 text-muted italic">{meal.note}</p>}
          {meal.description && <p class="mt-3 text-sub italic">{meal.description}</p>}
          <ul class="mt-5 list-none space-y-1.5 p-0">
            {meal.items.map((item) => (
              <li class="text-body">{item}</li>
            ))}
          </ul>
        </div>
      </Fragment>
    ))}
  </div>
</section>

---
import { getEntry, render } from "astro:content";

interface Props {
  locale: string;
  class?: string;
}

const { locale, class: className } = Astro.props;
const entry = await getEntry("dining", locale);
if (!entry) throw new Error(`Missing dining content for locale: ${locale}`);
const { Content } = await render(entry);
---

<section id="dining" class:list={["flex min-h-[80svh] flex-col items-center justify-center bg-section px-4 py-16", className]}>
  <div class="mx-auto max-w-2xl">
    <h2 class="mb-8 text-center font-normal text-head sm:text-5xl lg:text-6xl">{entry.data.title}</h2>
    <div class="prose prose-stone mx-auto text-body">
      <Content />
    </div>
  </div>
</section>
